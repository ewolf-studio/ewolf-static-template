# Déploiement SSH — copier ce fichier en .env et renseigner les valeurs.
# .env est ignoré par git (ne jamais committer d'identifiants réels).
#
# Format strict (parsé par deploy.sh, sans exécution de code) :
#   - une clé par ligne, CLE=valeur ;
#   - commentaires uniquement sur leur PROPRE ligne (pas en fin de valeur) ;
#   - valeurs sans espace ni caractères spéciaux (validées au chargement).

# Hôte ou alias ~/.ssh/config (ex. 192.168.1.131)
SSH_HOST=

# Utilisateur SSH
SSH_USER=

# Port SSH (22 par défaut si vide)
SSH_PORT=

# Dossier web distant servi par nginx (chemin absolu)
SSH_PATH=
